{
  "name": "rental-mgt-system",
  "version": "1.0.0",
  "description": "A native desktop app for rental management",
  "main": "electron/main.js",
  "author": "Ka-few <support@ka-few.com>",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently -k \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:frontend": "npm run dev --prefix src",
    "dev:electron": "wait-on http://localhost:5173 && electron . --no-sandbox",
    "dev:server": "node server/index.js",
    "web": "concurrently -k \"npm run dev:frontend\" \"npm run dev:server\"",
    "build": "npm run build --prefix src && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.4.0",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.rental.management",
    "productName": "Rental Management System",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "src/dist/**/*",
      "!**/*.db"
    ],
    "asar": true,
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "verifyUpdateCodeSignature": false
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    }
  }
}
